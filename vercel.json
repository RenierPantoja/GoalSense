{
  "rewrites": [
    { "source": "/api/runtime", "destination": "/api/misc?fn=runtime" },
    { "source": "/api/worker-control-plane/status", "destination": "/api/misc?fn=worker-control-plane-status" },
    { "source": "/api/worker-control-plane/readiness", "destination": "/api/misc?fn=worker-control-plane-readiness" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
