# GoalSense Backend Environment Variables
# Copy to .env and fill in values

# ─── Persistence Provider ───────────────────────────────────────────────────
# 'prisma' (default) requires DATABASE_URL.
# 'firebase' requires Firebase Admin credentials (no DATABASE_URL needed).
#
# E2 status (Firebase mode): ProviderHealth + Telegram (channels + deliveries)
# are backed by Firestore. Patterns / Alerts / Fixtures / LiveSnapshots / Odds
# still throw a clear "not implemented yet" error in firebase mode and require
# PERSISTENCE_PROVIDER=prisma until migrated (E3+).
#
# NOTE: run `npm run db:generate` (NOT `npx prisma generate`) to generate the
# Prisma client. The local binary completes in <1s; `npx prisma` may hang while
# re-resolving the package (especially inside OneDrive-synced folders).
PERSISTENCE_PROVIDER="prisma"

# Database (only required when PERSISTENCE_PROVIDER=prisma)
DATABASE_URL="postgresql://user:password@host:5432/goalsense?schema=public"

# Firebase Admin (only required when PERSISTENCE_PROVIDER=firebase)
# Option 1: full service account JSON (single line, escaped)
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Option 2: path to a service account JSON file (local convenience; NEVER commit the file)
FIREBASE_SERVICE_ACCOUNT_PATH=""
# Option 3: separate vars
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# App
APP_ENV="development"
PORT=4000
# Comma-separated allowed origins. Include the deployed frontend so it can call
# a locally-running backend (browsers allow HTTPS pages to reach http://localhost).
CORS_ORIGIN="http://localhost:5173,https://goal-sense.vercel.app"

# Live Monitoring Worker
LIVE_WORKER_ENABLED="false"
LIVE_WORKER_INTERVAL_MS=30000
ESPN_BASE_URL="https://site.api.espn.com/apis/site/v2/sports/soccer"

# Summary Enrichment
SUMMARY_ENRICHMENT_ENABLED="true"
SUMMARY_ENRICHMENT_MAX_FIXTURES=10

# Pattern Evaluation Worker
PATTERN_WORKER_ENABLED="false"
PATTERN_WORKER_INTERVAL_MS=15000
PATTERN_WORKER_MAX_FIXTURES=20

# Alert Resolution Worker
RESOLUTION_WORKER_ENABLED="false"
RESOLUTION_WORKER_INTERVAL_MS=30000
RESOLUTION_WORKER_MAX_ALERTS=50

# Telegram
TELEGRAM_ENABLED="false"
TELEGRAM_BOT_TOKEN=""

# Odds Intelligence (Phase D2 / D2.2)
ODDS_ENABLED="false"
ODDS_PROVIDER="none"           # none | api_football
ODDS_API_KEY=""                # falls back to API_FOOTBALL_KEY if empty
ODDS_FETCH_TIMEOUT_MS=8000
ODDS_CACHE_TTL_SECONDS=30

# Provider Keys (same as frontend functions)
API_FOOTBALL_KEY=""
FOOTBALL_DATA_KEY=""

# Future: Auth
# JWT_SECRET=""

# ─── B28: Cloud runtime ──────────────────────────────────────────────────────
# APP_ENV: local | development | staging | production | test
# Public URL of this backend + the frontend origin(s) allowed via CORS.
PUBLIC_BACKEND_URL=""
FRONTEND_ORIGIN=""
# Preferred over CORS_ORIGIN when set (comma-separated, no wildcard in prod).
CORS_ALLOWED_ORIGINS=""
# Optional build marker shown in /api/system/diagnostics.
BUILD_VERSION=""
# Firebase Admin via base64 service account (best for cloud env vars):
#   cat service-account.json | base64 -w0
FIREBASE_SERVICE_ACCOUNT_BASE64=""

# ─── B26/B27: Auth & guardrails ──────────────────────────────────────────────
ENABLE_AUTH="false"
ALLOW_DEV_AUTH_BYPASS="false"
DEV_AUTH_ROLE="owner"
REQUIRE_ADMIN_FOR_DANGEROUS_ACTIONS="true"
ENABLE_RATE_LIMIT="false"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_DEFAULT=120
RATE_LIMIT_MAX_REQUESTS_DANGEROUS=10

# ─── Auto Engine / Alert Policy (all OFF by default) ─────────────────────────
ENABLE_BACKTEST_API="false"
ENABLE_ALERT_EXPORT="false"
ENABLE_AUTO_ENGINE="false"
ENABLE_AUTO_ENGINE_WRITE="false"
ENABLE_AUTO_ENGINE_SCHEDULER="false"
ENABLE_AUTO_ENGINE_TO_ALERTS="false"
ENABLE_MANUAL_AUTO_OPPORTUNITY_PROMOTION="false"
ENABLE_PROMOTED_ALERT_MANUAL_RESOLVE="false"
ENABLE_AUTO_ENGINE_LEARNING_REBUILD="false"
ENABLE_AUTO_ENGINE_LEARNING_SCHEDULER="false"
ENABLE_AUTO_ALERT_POLICY="false"
ENABLE_AUTO_ALERT_SHADOW_MODE="true"
ENABLE_AUTO_ALERT_CREATE="false"
ENABLE_AUTO_ALERT_TELEGRAM="false"
ENABLE_AUTO_ALERT_POLICY_CONFIG="false"
