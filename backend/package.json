{
  "name": "goalsense-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "local:safe": "node scripts/runLocalSafeMode.mjs",
    "local:diagnostics": "node scripts/runLocalSafeMode.mjs",
    "smoke:local-ops": "node scripts/smokeLocalOperations.mjs",
    "smoke:pipeline-guards": "node scripts/smokeLivePipelineGuards.mjs",
    "smoke:snapshot-lifecycle": "node scripts/smokeSnapshotLifecycle.mjs",
    "smoke:evidence-lineage": "node scripts/smokeEvidenceLineage.mjs",
    "smoke:live-evidence": "node scripts/smokeLiveEvidenceCapture.mjs",
    "smoke:bt-replay-inline-evidence": "node scripts/smokeBacktestReplayInlineEvidence.mjs",
    "smoke:bt-replay-reprocess": "node scripts/smokeBacktestReplayEvidenceReprocessing.mjs",
    "smoke:live-validation": "node scripts/smokeLiveValidationSessions.mjs",
    "smoke:live-session-attribution": "node scripts/smokeLiveSessionAttribution.mjs",
    "smoke:live-session-record-index": "node scripts/smokeLiveSessionRecordIndex.mjs",
    "smoke:match-intelligence": "node scripts/smokeMatchIntelligenceFabric.mjs",
    "smoke:pre-match-acquisition": "node scripts/smokePreMatchAcquisition.mjs",
    "backfill:live-session-attribution": "node scripts/backfillLiveValidationSessionAttribution.mjs",
    "reindex:live-session-records": "node scripts/reindexLiveValidationSessionRecords.mjs",
    "reprocess:bt-replay-evidence": "node scripts/reprocessBacktestReplayEvidence.mjs",
    "backfill:bt-replay-inline-evidence": "node scripts/backfillBacktestReplayInlineEvidence.mjs",
    "backfill:evidence-lineage": "node scripts/backfillEvidenceLineage.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "qa:cleanup": "node scripts/firebaseCleanupQaData.mjs",
    "counters:rebuild-all": "node scripts/rebuildPerformanceCounters.mjs",
    "migrate:dryrun": "node scripts/migratePrismaToFirebase.mjs",
    "watch:live": "node scripts/watchLiveValidationWindow.mjs",
    "watch:live:long": "node scripts/watchLiveValidationWindow.mjs --duration 240 --interval 60 --json"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "dotenv": "^16.4.0",
    "firebase-admin": "^13.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "@types/node": "^22.0.0"
  }
}
