# GoalSense — Local Validation Campaign env example (B50)
# ─────────────────────────────────────────────────────────────────────────────
# Placeholders ONLY. Never commit a real API key or a real service account.
# The Firebase service account JSON is gitignored — keep it out of this file and the repo.
# Copy to `.env` (or `.env.local`) and fill the placeholders locally.

APP_ENV=local

# ── Persistence ──
# Validation metrics/cases persist ONLY under firebase. Provide credentials separately
# (FIREBASE_SERVICE_ACCOUNT_PATH / _BASE64 / _JSON or FIREBASE_PROJECT_ID+CLIENT_EMAIL+PRIVATE_KEY).
PERSISTENCE_PROVIDER=firebase
# FIREBASE_SERVICE_ACCOUNT_PATH=./your-service-account.json   # NEVER commit this file

# ── Provider (start OFF; turn ON only when you have a real key + mappings) ──
ENABLE_PROVIDER_API_FOOTBALL=false
API_FOOTBALL_KEY=
ENABLE_PRE_MATCH_ACQUISITION=true
ENABLE_PRE_MATCH_ACQUISITION_SCHEDULER=false

# ── Local long-run validation (manual-first; scheduler OFF) ──
ENABLE_LOCAL_LONG_RUN_VALIDATION=true
LOCAL_VALIDATION_MODE=shadow_only
ENABLE_LOCAL_VALIDATION_SCHEDULER=false

# ── Governance (observe-first; enforce MUST stay OFF during validation) ──
ENABLE_ALERT_DECISION_GOVERNANCE=true
ALERT_GOVERNANCE_MODE=observe
ENABLE_ALERT_GOVERNANCE_ENFORCE=false

# ── Live re-evaluation bridge (OFF by default; turn ON only to test live recheck) ──
ENABLE_LOCAL_LIVE_RECHECK_BRIDGE=false
LOCAL_LIVE_RECHECK_BRIDGE_MODE=observe
# LOCAL_LIVE_RECHECK_MIN_INTERVAL_SECONDS=60

# ── Causal learning (manual-first; scheduler OFF) ──
ENABLE_CAUSAL_LEARNING=true
ENABLE_CAUSAL_LEARNING_SCHEDULER=false

# ── Must stay OFF during local validation ──
TELEGRAM_ENABLED=false
ODDS_ENABLED=false

# Flags to turn ON manually only when ready:
#   - ENABLE_PROVIDER_API_FOOTBALL=true (with API_FOOTBALL_KEY + confirmed mappings)
#   - ENABLE_LOCAL_LIVE_RECHECK_BRIDGE=true (observe-only; rate-limited)
# Flags that MUST remain OFF in this phase:
#   - ENABLE_ALERT_GOVERNANCE_ENFORCE (no enforce)
#   - TELEGRAM_ENABLED / ODDS_ENABLED (no Telegram / no odds)
