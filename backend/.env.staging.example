# GoalSense Backend — STAGING environment example (Phase B28)
# Copy to your platform's env config. NEVER commit real values.
# Conservative defaults: every dangerous capability is OFF until go/no-go.

# ── Runtime ──────────────────────────────────────────────────────────────────
APP_ENV="staging"
NODE_ENV="production"
PORT=4000
# Public URL of THIS backend (used in diagnostics / docs).
PUBLIC_BACKEND_URL="https://your-staging-backend.example.com"
# Frontend origin(s) allowed to call this backend (Bearer token requires this).
FRONTEND_ORIGIN="https://goal-sense-staging.vercel.app"
CORS_ALLOWED_ORIGINS="https://goal-sense-staging.vercel.app,http://localhost:5173"

# ── Persistence (Firebase in cloud) ───────────────────────────────────────────
PERSISTENCE_PROVIDER="firebase"
# Preferred for cloud: base64-encoded service account JSON (single env var).
#   cat service-account.json | base64 -w0   (Linux)  → paste below
FIREBASE_SERVICE_ACCOUNT_BASE64=""
# OR separate vars (private key keeps literal \n escapes):
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# ── Auth & security (recommended ON in staging) ───────────────────────────────
ENABLE_AUTH="true"
ALLOW_DEV_AUTH_BYPASS="false"
REQUIRE_ADMIN_FOR_DANGEROUS_ACTIONS="true"
ENABLE_RATE_LIMIT="true"

# ── Feature flags (conservative — keep dangerous ones OFF) ────────────────────
ENABLE_BACKTEST_API="false"
ENABLE_ALERT_EXPORT="false"
ENABLE_AUTO_ENGINE="false"
ENABLE_AUTO_ENGINE_WRITE="false"
ENABLE_AUTO_ALERT_POLICY="false"
ENABLE_AUTO_ALERT_CREATE="false"
ENABLE_AUTO_ENGINE_TO_ALERTS="false"
ENABLE_MANUAL_AUTO_OPPORTUNITY_PROMOTION="false"
ENABLE_PROMOTED_ALERT_MANUAL_RESOLVE="false"

# ── Workers/schedulers (OFF until explicitly validated) ───────────────────────
LIVE_WORKER_ENABLED="false"
PATTERN_WORKER_ENABLED="false"
RESOLUTION_WORKER_ENABLED="false"
ENABLE_LEARNING_AGGREGATION_SCHEDULER="false"
ENABLE_AUTO_ENGINE_SCHEDULER="false"
ENABLE_AUTO_ENGINE_LEARNING_SCHEDULER="false"

# ── Never enabled in this phase ───────────────────────────────────────────────
TELEGRAM_ENABLED="false"
ODDS_ENABLED="false"

# Provider keys (only if live workers are later enabled)
API_FOOTBALL_KEY=""
FOOTBALL_DATA_KEY=""
