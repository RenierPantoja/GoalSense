rules_version = '2';

// GoalSense Firestore Security Rules — B67 (Raw Collections Locked Down)
// ─────────────────────────────────────────────────────────────────────────────
// Minimal public surface: the hosted Vercel Control Plane reads ONLY the
// sanitized `controlPlanePublicSummaries` collection (allowlisted fields).
//
// Security model:
//   - The local/dedicated worker writes via the Firebase Admin SDK (service
//     account), which BYPASSES these rules. Locking client reads/writes below
//     never affects the worker.
//   - All raw operational collections are now private (no public client read).
//   - Public read is limited to the sanitized summaries; client writes denied;
//     default-deny for everything else.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public surface: sanitized control-plane summaries only ────────────────
    match /controlPlanePublicSummaries/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── Default deny: ALL raw operational collections + everything else ───────
    // espnLiveFirstWorkerRuns, espnLiveFirstFixtureLeases, liveMonitoringSessions,
    // liveMonitoringFixtureStates, dailyValidationReports, validationCampaigns,
    // causalLearningCases, espnLiveFirstRecoveryReports, liveFirstPostMatchOutcomes,
    // liveSnapshots, signalLedger, alerts, patterns, intelligence memory, etc.
    // are all locked to clients. The Admin SDK (worker/backend) bypasses rules.
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
